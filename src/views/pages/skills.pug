extends ../layout

block content

  div(class="flex items-center justify-between mb-6")
    div
      h1(class="text-2xl font-bold text-gray-900 tracking-tight" style="margin-bottom:2px") Skills
      p(class="text-sm text-gray-500") Global skill library — assign to any agent
    button(class="btn btn-teal" data-modal-open="modal-new-skill") + New skill

  if skills.length === 0
    div(class="card p-12 text-center")
      p(class="text-gray-400 text-sm mb-3") No skills yet.
      button(class="btn btn-teal" data-modal-open="modal-new-skill") + Create skill
  else
    each cat in Object.keys(grouped)
      h2(class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3 mt-5")= cat
      div(class="grid gap-3" style="grid-template-columns:repeat(auto-fill,minmax(230px,1fr))")
        each skill in grouped[cat]
          div(class="card flex items-start gap-3 group" style="padding:14px")
            div(class="w-9 h-9 rounded-lg bg-main-bg border border-gray-200 flex items-center justify-center text-lg flex-shrink-0")= skill.icon
            div(class="flex-1 min-w-0")
              div(class="flex items-start justify-between gap-2")
                div
                  div(class="text-sm font-semibold text-gray-800" style="margin-bottom:2px")= skill.name
                  div(class="text-xs text-gray-500")= skill.description
                button(class="opacity-0 group-hover:opacity-100 text-gray-300 hover:text-red-400 text-xs transition-opacity flex-shrink-0" onclick=`deleteSkill('${skill._id}')` title="Delete skill") ✕

block overlays
  div(class="modal-backdrop" id="modal-new-skill")
    div(class="modal p-6")
      div(class="flex items-center justify-between mb-5")
        h2(class="text-base font-bold text-gray-900") New skill
        button(class="text-gray-400 hover:text-gray-600 text-lg" data-modal-close="modal-new-skill") ×
      form(class="flex flex-col gap-4" id="skill-create-form")
        div(class="grid grid-cols-2 gap-3")
          div
            label(class="label") Icon (emoji)
            input(class="field" type="text" name="icon" placeholder="⚡" maxlength="2")
          div
            label(class="label") Category
            select(class="field" name="category")
              each c in ['Data','Comms','Content','Integrations','System']
                option(value=c)= c
        div
          label(class="label") Skill name
          input(class="field" type="text" name="name" placeholder="e.g. Web Scraper" required)
        div
          label(class="label") Description
          input(class="field" type="text" name="description" placeholder="e.g. Scrape and parse web pages")
        div(class="flex gap-3 pt-1")
          button(class="btn btn-teal flex-1" type="submit") Create skill
          button(class="btn btn-ghost" type="button" data-modal-close="modal-new-skill") Cancel

block scripts
  script.
    async function deleteSkill(id) {
      if (!confirm('Delete this skill?')) return;
      var res = await fetch('/skills/'+id,{method:'DELETE',headers:{Accept:'application/json'}}).then(r=>r.json());
      if (res.ok) location.reload();
    }
