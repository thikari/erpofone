extends ../layout

block content

  div(class="flex items-center justify-between mb-6")
    div
      h1(class="text-2xl font-bold text-gray-900 tracking-tight" style="margin-bottom:2px") Daily Reports
      p(class="text-sm text-gray-500") Agent summaries · refreshed as agents submit

  if dates.length === 0
    div(class="card p-12 text-center")
      p(class="text-sm text-gray-400 mb-3") No reports yet.
      p(class="text-xs text-gray-400 mb-1") Agents submit reports via:
      code(class="block text-xs font-mono bg-gray-50 border border-gray-200 rounded px-3 py-2 text-gray-600 text-left mx-auto" style="max-width:480px")
        | POST /api/ingest/report
        br
        | {"agentName":"…","summary":"…","highlights":["…"],"tasksDone":3,"tasksTotal":3,"tokens":12000,"cost":0.12}

  each group in dates
    div(class="mb-8")
      div(class="flex items-center gap-3 mb-3")
        span(class="text-xs font-semibold text-gray-400 uppercase tracking-widest")= group.dateKey
        hr(class="flex-1 border-gray-100")

      div(class="flex flex-col gap-3")
        each report in group.reports
          div(class="card p-4")
            div(class="flex items-start gap-3 mb-3")
              div(class="w-8 h-8 rounded-lg flex items-center justify-center text-xs font-bold flex-shrink-0 text-white" style="background:linear-gradient(135deg,#14b8a6,#0891b2)")
                = report.agentName.slice(0,2).toUpperCase()
              div(class="flex-1 min-w-0")
                div(class="flex items-center gap-2 mb-0.5")
                  span(class="text-sm font-semibold text-gray-900")= report.agentName
                  span(class=`pill pill-${report.period === 'weekly' ? 'queued' : 'running'}` style="font-size:10px")= report.period
                if report.summary
                  p(class="text-sm text-gray-600 leading-relaxed")= report.summary
            if report.highlights && report.highlights.length > 0
              ul(class="mb-3 pl-4 flex flex-col gap-0.5")
                each h in report.highlights
                  li(class="text-xs text-gray-500 list-disc")= h
            div(class="flex items-center gap-4 text-xs font-mono text-gray-400 border-t border-gray-100 pt-3")
              span #{report.tasksDone}/#{report.tasksTotal} tasks
              if report.tokens > 0
                span #{(report.tokens / 1000).toFixed(1)}K tokens
              if report.cost > 0
                span €#{report.cost.toFixed(2)}
              span(class="ml-auto")= new Date(report.createdAt).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'})
